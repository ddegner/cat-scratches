    },
    "To enable or configure the extension:\n\n1. Open Settings → Apps → Safari\n2. Tap Extensions\n3. Tap Cat Scratches to enable and configure" : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Um die Erweiterung zu aktivieren oder zu konfigurieren:\n\n1. Öffne Einstellungen → Apps → Safari\n2. Tippe auf Erweiterungen\n3. Tippe auf Katzenkratzer zum Aktivieren und Konfigurieren" } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "Para activar o configurar la extensión:\n\n1. Abre Ajustes → Apps → Safari\n2. Toca Extensiones\n3. Toca Arañazos de Gato para activar y configurar" } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "Pour activer ou configurer l'extension :\n\n1. Ouvrez Réglages → Apps → Safari\n2. Touchez Extensions\n3. Touchez Griffures de Chat pour activer et configurer" } },
        "ja" : { "stringUnit" : { "state" : "translated", "value" : "機能拡張を有効化または設定するには：\n\n1. 設定 → アプリ → Safari を開く\n2. 機能拡張をタップ\n3. ネコスクラッチをタップして有効化・設定" } },
        "nl" : { "stringUnit" : { "state" : "translated", "value" : "Om de extensie in te schakelen of te configureren:\n\n1. Open Instellingen → Apps → Safari\n2. Tik op Extensies\n3. Tik op Kattenkrabben om in te schakelen en te configureren" } },
        "vi" : { "stringUnit" : { "state" : "translated", "value" : "Để bật hoặc cấu hình tiện ích mở rộng:\n\n1. Mở Cài đặt → Ứng dụng → Safari\n2. Chạm Tiện ích mở rộng\n3. Chạm Vết Mèo Cào để bật và cấu hình" } }
      }
    },
