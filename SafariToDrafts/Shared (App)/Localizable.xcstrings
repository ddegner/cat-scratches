    "The extension will use the Share Sheet because Drafts is not detected." : {
      "localizations" : {
        "de" : { "stringUnit" : { "state" : "translated", "value" : "Die Erweiterung nutzt das Teilen-Menü, da Drafts nicht erkannt wurde." } },
        "es" : { "stringUnit" : { "state" : "translated", "value" : "La extensión usará la hoja de compartir porque no se detectó Drafts." } },
        "fr" : { "stringUnit" : { "state" : "translated", "value" : "L'extension utilisera la feuille de partage car Drafts n'est pas détecté." } },
