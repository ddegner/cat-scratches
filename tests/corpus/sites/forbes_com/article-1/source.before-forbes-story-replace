        /** @function showComponentSuccess
         * Helper function to show success state for a component element
         * @param {HTMLElement} parentElement - The component container element
        */
        const showComponentSuccess = (parentElement) => {
            if (parentElement) {
                const successScreen = parentElement.querySelector('#success-screen');
                const initialScreen = parentElement.querySelector('#initial-screen');

                successScreen.style.display = 'block';
                initialScreen.style.display = 'none';
            }
        }

        /** @function submitUserData
         * Submits user data and updates the UI accordingly.
        */
        async function submitUserData() {
            const userEmailInput = emailInput.value;
            if (emailRegExp.test(userEmailInput)) {
                templateParams['userEmailInput'] = userEmailInput;
                window.forbes.nlData = {
                    email: userEmailInput,
                };
                window.Zephr.utils.updateCordialListData(templateParams);

                const inlineComponents = document.querySelectorAll('.newsletter-inline-footer');
                const landerComponent = document.querySelector('.newsletter-inline-flex');

                inlineComponents.forEach(component => showComponentSuccess(component));
                if (landerComponent) {
                    showComponentSuccess(landerComponent);
                }

                window.fbq('track', 'Lead');
                trackEvent('click-unknown-signup');
            } else if (userEmailInput === '') {
                showErrorMessage(true, 'Please enter your email');
                return;
            }
        }
        const newsletterParentElement = document.currentScript.previousElementSibling;

        const emailInput = newsletterParentElement.querySelector('.zephr-components-garden-input-wrapper input');
        const emailRegExp =
            window.Zephr?.utils?.emailRegex ?? /^(([^<>()\[\]\\.,;:\s@"]+(\.[^<>()\[\]\\.,;:\s@"]+)*)|(".+"))@((\[[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}\.[0-9]{1,3}])|(([a-zA-Z\-0-9]+\.)+[a-zA-Z]{2,}))$/;
        const errorMessage = newsletterParentElement.querySelector(
            '.newsletter-inline-error-message',
        );
        const submitButton = newsletterParentElement.querySelector(
            '.newsletter-email-submit-button',
        );
        const gRecaptcha = newsletterParentElement.querySelector('.g-recaptcha');

        let successScreen = newsletterParentElement.querySelector('#success-screen');
        let initialScreen = newsletterParentElement.querySelector('#initial-screen');
        const successButtons = newsletterParentElement.querySelectorAll('.success-buttons-container a, .success-buttons-container button');

        const newsletter = 'DailyDozen';
        const imageUrl = '';
        const geolocation = 'US';
        const featureName = 'hamburger-newsletter-inline';
        const outcomeLabel = window.Zephr.outcomes[featureName]?.outcomeLabel;
        const isHamburgerMenu = featureName === 'hamburger-newsletter-inline';
        const isInlineLanderFeaturePresent = window.Zephr?.outcomes?.['homepage_newsletter_sign_up'];

        let gRecaptchaCallbackName = 'gRecaptchaCallbackFooter';
        let gRecaptchaCallbackToRemove = 'gRecaptchaCallbackHamburger';

        const templateParams = {
            newsletter,
            geolocation,
            outcomeLabel,
            Announcements: true,
            lander: true,
        };

        submitButton.disabled = true;
        const gPrivacyPolicy = '<a href="https://policies.google.com/privacy" target="_blank">Privacy Policy</a>';
        const gTermsOfService = '<a href="https://policies.google.com/terms" target="_blank">Terms of Service</a>';
        const googlCaptchaText = `Forbes is protected by reCAPTCHA, and the Google ${gPrivacyPolicy} and ${gTermsOfService} apply.`;
        const termsOfService = '<a href="https://www.forbes.com/terms-and-conditions" target="_blank">Terms of Service</a>';
